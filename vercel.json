{
  "functions": {
    "api/mcp.mjs": {
      "includeFiles": "build/mcp/**"
    }
  },
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    }
  ],
  "redirects": [
    {
      "source": "/blog/tags/:tag*",
      "destination": "/blog/tag/:tag*",
      "permanent": true
    },
    {
      "source": "/docs/v2/HyperIndex/:path*",
      "destination": "/docs/HyperIndex/:path*",
      "permanent": true
    }
  ]
}
