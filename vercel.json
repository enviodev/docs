{
  "functions": {
    "api/mcp.mjs": {
      "includeFiles": "build/mcp/**"
    }
  },
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/docs/:path*",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/markdown.*"
        }
      ],
      "destination": "/docs/:path*.md"
    },
    {
      "source": "/blog/:slug",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/markdown.*"
        }
      ],
      "destination": "/blog/:slug.md"
    }
  ],
  "redirects": [
    {
      "source": "/blog/tags/:tag*",
      "destination": "/blog/tag/:tag*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*).md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        }
      ]
    },
    {
      "source": "/llms(.*).txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ]
}
